{
  "name": "froth",
  "displayName": "Froth",
  "description": "Live development for Froth microcontrollers",
  "version": "0.0.1",
  "publisher": "froth",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "froth.sendSelection",
        "title": "Froth: Send Selection / Line"
      },
      {
        "command": "froth.sendFile",
        "title": "Froth: Send File"
      }
    ],
    "keybindings": [
      {
        "command": "froth.sendSelection",
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
