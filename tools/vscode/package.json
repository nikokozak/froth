{
  "name": "froth",
  "displayName": "Froth",
  "description": "Live development for Froth microcontrollers",
  "version": "0.0.2",
  "publisher": "froth",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "froth.connect",
        "title": "Froth: Connect Device",
        "icon": "$(plug)"
      },
      {
        "command": "froth.tryLocal",
        "title": "Froth: Try Local POSIX",
        "icon": "$(terminal)"
      },
      {
        "command": "froth.doctor",
        "title": "Froth: Run Doctor",
        "icon": "$(tools)"
      },
      {
        "command": "froth.sendSelection",
        "title": "Froth: Send Selection / Line",
        "icon": "$(play)"
      },
      {
        "command": "froth.sendFile",
        "title": "Froth: Send File (Reset + Eval)",
        "icon": "$(file-code)"
      },
      {
        "command": "froth.interrupt",
        "title": "Froth: Interrupt",
        "icon": "$(debug-stop)"
      },
      {
        "command": "froth.reset",
        "title": "Froth: Reset to Baseline",
        "icon": "$(refresh)"
      },
      {
        "command": "froth.save",
        "title": "Froth: Save Snapshot",
        "icon": "$(save)"
      },
      {
        "command": "froth.wipe",
        "title": "Froth: Wipe Snapshots",
        "icon": "$(trash)"
      },
      {
        "command": "froth.refreshSidebar",
        "title": "Froth: Refresh Device Info",
        "icon": "$(refresh)"
      }
    ],
    "keybindings": [
      {
        "command": "froth.sendSelection",
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "when": "editorTextFocus && resourceExtname == .froth"
      },
      {
        "command": "froth.sendFile",
        "key": "ctrl+shift+enter",
        "mac": "cmd+shift+enter",
        "when": "editorTextFocus && resourceExtname == .froth"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "froth",
          "title": "Froth",
          "icon": "$(symbol-misc)"
        }
      ]
    },
    "views": {
      "froth": [
        {
          "id": "frothDeviceView",
          "name": "Device"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "frothDeviceView",
        "contents": "Connect to a Froth device or start a local POSIX target.\n\n[Connect Device](command:froth.connect)\n[Try Local](command:froth.tryLocal)\n[Run Doctor](command:froth.doctor)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "froth.interrupt",
          "when": "view == frothDeviceView",
          "group": "navigation"
        },
        {
          "command": "froth.refreshSidebar",
          "when": "view == frothDeviceView",
          "group": "navigation"
        },
        {
          "command": "froth.reset",
          "when": "view == frothDeviceView",
          "group": "2_actions"
        },
        {
          "command": "froth.save",
          "when": "view == frothDeviceView",
          "group": "2_actions"
        },
        {
          "command": "froth.wipe",
          "when": "view == frothDeviceView",
          "group": "2_actions"
        },
        {
          "command": "froth.doctor",
          "when": "view == frothDeviceView",
          "group": "2_actions"
        }
      ],
      "editor/title": [
        {
          "command": "froth.sendSelection",
          "when": "resourceExtname == .froth",
          "group": "navigation"
        },
        {
          "command": "froth.sendFile",
          "when": "resourceExtname == .froth",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
