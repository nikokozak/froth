# Console: UART0 at 115200 baud (default for most DevKit boards)
CONFIG_ESP_CONSOLE_UART_DEFAULT=y
CONFIG_ESP_CONSOLE_UART_BAUDRATE=115200

# Disable task watchdog. Froth execution loops do not yield to
# FreeRTOS, so the watchdog would fire during any long-running
# Froth program. Safe for development; revisit for production.
CONFIG_ESP_TASK_WDT_EN=n

# Flash
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y

# FreeRTOS
CONFIG_FREERTOS_HZ=1000
