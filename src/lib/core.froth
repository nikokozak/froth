'dup ( a -- a a )   [1 p[a a] perm] def

'swap ( b a -- a b )   [2 p[a b] perm] def

'drop ( a -- )   [1 p[] perm] def

'over ( b a -- b a b )   [2 p[b a b] perm] def

'rot ( c b a -- b a c )   [3 p[b a c] perm] def

'-rot ( c b a -- a c b )   [3 p[a c b] perm] def

'nip ( b a -- a )   [2 p[a] perm] def

'tuck ( b a -- a b a )   [2 p[a b a] perm] def
